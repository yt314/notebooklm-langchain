# Copy to .env and fill in. Loaded automatically via python-dotenv.

# --- Chat model (default provider: Google Gemini) ---
GOOGLE_API_KEY=...
# Override the default chat model if you like:
# NOTEBOOKLM_CHAT_MODEL=google_genai:gemini-flash-latest

# --- Embeddings (default provider: Cohere) ---
COHERE_API_KEY=...
# NOTEBOOKLM_EMBEDDING_PROVIDER=cohere
# NOTEBOOKLM_EMBEDDING_MODEL=embed-multilingual-v3.0

# --- Web search sources (stage 3) ---
FIRECRAWL_API_KEY=...
